"use server";

import { revalidatePath } from "next/cache";
import { prisma } from "@/src/lib/prisma";
import { requireRole } from "@/app/lib/dal";

export async function enroll(courseId: string) {
  const session = await requireRole("STUDENT");

  await prisma.enrollment.upsert({
    where: {
      studentId_courseId: {
        studentId: session.userId,
        courseId,
      },
    },
    create: {
      studentId: session.userId,
      courseId,
    },
    update: {},
  });

  revalidatePath(`/courses/${courseId}`);
  revalidatePath("/profile");
}

export async function leave(courseId: string) {
  const session = await requireRole("STUDENT");

  await prisma.enrollment.deleteMany({
    where: {
      studentId: session.userId,
      courseId,
    },
  });

  revalidatePath(`/courses/${courseId}`);
  revalidatePath("/profile");
}

export async function setGrade(formData: FormData) {
  const session = await requireRole("DOCENT", "ADMIN");

  const enrollmentId = formData.get("enrollmentId") as string;
  const gradeRaw = formData.get("grade") as string;
  const grade = gradeRaw === "" ? null : Number(gradeRaw);

  if (grade !== null && (Number.isNaN(grade) || grade < 1 || grade > 10)) {
    return;
  }

  const enrollment = await prisma.enrollment.findUnique({
    where: { id: enrollmentId },
    select: {
      courseId: true,
      course: {
        select: {
          docentId: true,
        },
      },
    },
  });

  if (!enrollment) return;

  if (
    session.role === "DOCENT" &&
    enrollment.course.docentId !== session.userId
  ) {
    return;
  }

  await prisma.enrollment.update({
    where: {
      id: enrollmentId,
    },
    data: {
      grade,
    },
  });

  revalidatePath(`/courses/${enrollment.courseId}`);
}

export async function removeStudent(enrollmentId: string) {
  const session = await requireRole("DOCENT", "ADMIN");

  const enrollment = await prisma.enrollment.findUnique({
    where: { id: enrollmentId },
    select: {
      courseId: true,
      course: {
        select: {
          docentId: true,
        },
      },
    },
  });

  if (!enrollment) return;

  if (
    session.role === "DOCENT" &&
    enrollment.course.docentId !== session.userId
  ) {
    return;
  }

  await prisma.enrollment.delete({
    where: {
      id: enrollmentId,
    },
  });

  revalidatePath(`/courses/${enrollment.courseId}`);
}


